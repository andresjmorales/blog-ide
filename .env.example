# Supabase (required for auth + cloud sync)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# Set to true only on the blogide.com (or other hosted) deploy.
# Self-host / local installs leave this unset or false so landing copy
# stays product-first without hosted scarcity messaging.
# NEXT_PUBLIC_HOSTED=true
